{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build with d-mingw",
            "type": "shell",
            "command": "D:/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Use D:/mingw64 toolchain to build current file"
        }
    ]
}
