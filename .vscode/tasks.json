{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build with d-mingw",
            "type": "shell",
            "command": "D:/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "-I",
                "D:/mingw64/include",
                "-L",
                "D:/mingw64/lib",
                "${file}",
                "-leasyx",
                "-lgdi32",
                "-lwinmm",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Use D:/mingw64 toolchain to build current file"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "D:\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I",
                "D:\\mingw64\\include",
                "-L",
                "D:\\mingw64\\lib",
                "${file}",
                "-leasyx",
                "-lgdi32",
                "-lwinmm",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "D:\\mingw64\\bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "调试器生成的任务。"
        }
    ]
}